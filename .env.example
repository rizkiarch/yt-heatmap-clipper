# RabbitMQ background queue
RABBITMQ_URL=amqp://username:password@rabbitmq.hawakanbarokah.id:5672/%2F
RABBITMQ_QUEUE=yt_heatmap_clipper_jobs

# Toggle asynchronous queue mode in web app
ASYNC_ENABLED=1

# If queue publish fails, fallback to local background thread
ASYNC_FALLBACK_SYNC=1

# ── YouTube Anti-Bot Configuration ───────────────────────────────────────────
# yt-dlp may require cookies to bypass "Sign in to confirm you're not a bot".
# Method 1: Export cookies from browser to a file (strongest method).
#   - Place cookies.txt in project root, OR set YTDLP_COOKIES_FILE path.
#   - Use Chrome extension "Get cookies.txt LOCALLY" to export from youtube.com.
# Method 2: Read cookies directly from browser (yt-dlp auto-extracts).
#   - Set to: chrome, firefox, edge, safari, opera, chromium
# Method 3: PO Token + Visitor Data (when cookies unavailable).
#   - Get from browser dev tools Network tab while playing a YouTube video.
#   - Search "player" request, copy "po_token" and "visitorData" values.
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=
