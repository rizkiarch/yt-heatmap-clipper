# RabbitMQ background queue
RABBITMQ_URL=amqp://username:password@rabbitmq.hawakanbarokah.id:5672/%2F
RABBITMQ_QUEUE=yt_heatmap_clipper_jobs

# Toggle asynchronous queue mode in web app
ASYNC_ENABLED=1

# If queue publish fails, fallback to local background thread
ASYNC_FALLBACK_SYNC=1

# ── YouTube Anti-Bot Configuration ───────────────────────────────────────────
# yt-dlp may require cookies to bypass "Sign in to confirm you're not a bot".
# See: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# See: https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
#
# ⚠️ WARNING: Using your YouTube account with yt-dlp risks being banned
# (temporarily or permanently). Consider using a secondary/throwaway account.
#
# Method 1: Export cookies from browser to a file (RECOMMENDED for YouTube).
#   1. Open an Incognito/Private window in your browser.
#   2. Log into youtube.com with your account.
#   3. Open ONLY https://www.youtube.com/robots.txt as the only tab.
#   4. Use browser extension to export ONLY youtube.com cookies in Netscape format:
#      Chrome: "Get cookies.txt LOCALLY" (the old "Get cookies.txt" was malware)
#      Firefox: "cookies.txt" extension
#   5. Save as cookies.txt in project root, OR set YTDLP_COOKIES_FILE path.
#   6. Close the incognito window permanently — never reopen it.
#   NOTE: The file must start with "# HTTP Cookie File" or "# Netscape HTTP Cookie File".
#   Windows needs CRLF line endings; Linux/Mac needs LF. HTTP Error 400 = wrong endings.
#
# Method 2: Read cookies directly from browser (easier, less reliable for YouTube).
#   Set to: chrome, firefox, edge, safari, opera, chromium
#   Flatpak Chrome: chrome:~/.var/app/com.google.Chrome/
#   NOTE: Do NOT combine with Method 1 (cookies file) for YouTube — incognito
#   session cookies won't be read from the browser profile.
#
# Method 3: PO Token + Visitor Data (NOT recommended, last resort).
#   Get from browser dev tools (F12 → Network → "player" request payload).
#   This skips webpage requests, making extraction less stable.
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=
